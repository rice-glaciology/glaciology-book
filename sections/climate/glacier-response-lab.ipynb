}

for name, g in glaciers.items():
    g['tau'] = g['H'] / abs(g['bt'])
    g['geom'] = g['L0'] / g['H']      # the factor (Ybar/Yt)(L0/H0) with Ybar/Yt = 1
    print(f"{name:14s}  tau = {g['tau']:5.1f} yr   L0/H0 = {g['geom']:5.1f}")
