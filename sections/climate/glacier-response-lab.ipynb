# t1, H1, L1 = run_robel(bed_prograde, 2000.0, 400.0e3, P_bar, 30000.0)

# Experiment 2: 5% drop in accumulation from the spun-up state
# t2, H2, L2 = run_robel(bed_prograde, H1[-1], L1[-1], 0.95 * P_bar, 30000.0)

