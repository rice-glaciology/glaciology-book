```python
# Your calculation for Task 2 here.
lambda_c = 0.0555   # m, Sentinel-1 C-band
theta_i  = np.radians(35.0)
delta_z  = 1.0      # m, tidal amplitude

# delta_r = delta_z * cos(theta_i)  (vertical displacement maps to range)
